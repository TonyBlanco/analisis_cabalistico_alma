FROM node:20-alpine AS deps
WORKDIR /app
COPY packages/symbolic ./packages/symbolic
COPY tonyblanco-app/package.json tonyblanco-app/package-lock.json ./tonyblanco-app/
WORKDIR /app/tonyblanco-app
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
COPY packages/symbolic ./packages/symbolic
COPY tonyblanco-app ./tonyblanco-app
WORKDIR /app/tonyblanco-app
COPY --from=deps /app/tonyblanco-app/node_modules ./node_modules
ARG NEXT_PUBLIC_API_URL=https://api.studios33.app/api
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1
ENV STUDIOS33_DEPLOY=1
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app/tonyblanco-app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
COPY --from=builder /app/tonyblanco-app ./
EXPOSE 3000
CMD ["npm", "start"]
