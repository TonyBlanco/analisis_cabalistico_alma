.vercel
# Ignorar directorios de Nuxt
.nuxt/
.output/

# Ignorar dependencias de Node
node_modules/

# Ignorar archivos y directorios de Vercel
.vercel/
.vercel_build_output/ # A veces también se genera este

# Ignorar archivos de entorno
.env
.env.*.local

# Si tienes "package old" y no lo necesitas, ignóralo o bórralo
package old/
package old.json

# Si la carpeta 'app/' no es parte de tu estructura Nuxt real, ignórala
# Pero antes, asegúrate de que no contenga código fuente valioso.
# Si contiene algo importante, muévelo a la raíz o a 'pages/' o 'components/'
# y luego ignora la carpeta 'app/' si sigue siendo irrelevante para Nuxt.
# POR AHORA, no la ignores si crees que tiene código fuente.
# Podrías necesitar borrarla o mover su contenido si es un remanente de Next.js.
# app/ # Descomenta si estás SEGURO de que no necesitas esta carpeta