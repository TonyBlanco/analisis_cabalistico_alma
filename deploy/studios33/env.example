# Copiar a /opt/studio33/.env en el servidor (no versionar).
# Secretos locales (Turnstile + Google): deploy/studios33/.env.studios33 — ver docs/01_PROJECT_STATE/SESSION_2026-06-05_STUDIOS33.md

DEBUG=False
SECRET_KEY=change-me
ALLOWED_HOSTS=api.studios33.app,studios33.app,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://studios33.app,https://www.studios33.app
CSRF_TRUSTED_ORIGINS=https://studios33.app,https://www.studios33.app,https://api.studios33.app
FRONTEND_URL=https://studios33.app

DATABASE_URL=postgresql://studio33_user:CHANGE_PASSWORD@postgres:5432/studio33_db?sslmode=disable

SWISSEPH_PATH=/app/astrology/ephemeris

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Process Memory Phase 1 — embeddings (lexical = empty vectors; ollama = nomic-embed-text)
# PROCESS_MEMORY_EMBEDDINGS=lexical
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

NEXT_PUBLIC_API_URL=https://api.studios33.app/api

ADMIN_DEFAULT_PASSWORD=change-me-admin

# Cloudflare Turnstile (login + registro) — claves reales en deploy/studios33/.env.studios33 (local, gitignored)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Sign-In (OAuth 2.0 Web client — solo GOOGLE_CLIENT_ID en servidor; ver guía en respuesta / backend/.env.example)
GOOGLE_CLIENT_ID=
# Alias compatible con VoxTV:
# TURNSTILE_SECRET=
TURNSTILE_ENFORCED=true

# Email (invitaciones terapeuta → consultante). Proton SMTP (contraseña de aplicación, no login):
# PROTON_SMTP_USER=noreply@studios33.app PROTON_SMTP_TOKEN=... bash deploy/studios33/scripts/patch-proton-smtp-env.sh
# Alternativa VoxTV (Gmail): patch-smtp-env.sh
EMAIL_HOST=smtp.protonmail.ch
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=noreply@studios33.app
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Studios33 <noreply@studios33.app>
EMAIL_SUBJECT_PREFIX=[Studios33]