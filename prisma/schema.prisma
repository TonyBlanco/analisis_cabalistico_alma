
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/analisis_cabalistico_alma/app/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model AnalisisCabalistico {
  id                    String   @id @default(cuid())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  // Datos personales
  nombreCompleto       String
  fechaNacimiento      DateTime
  lugarNacimiento      String?
  horaNacimiento       String?
  
  // Cálculos numerológicos
  numeroAlma           Int
  numeroPersonalidad   Int
  numeroTikkun         Int
  numeroSombra         Int
  numeroCorazon        Int
  efectoSanador        Int
  lemaVida             Int
  
  // Vibraciones
  vibracionCuerpo      Int
  vibracionAlma        Int
  vibracionEspiritu    Int
  
  // Letras hebreas
  letrasHebreas        String[]
  
  // Cartas del Tarot
  cartaOrigen          String
  cartaTransformacion  String
  cartaDestino         String
  
  // Sefirot asociadas
  sefirotPrincipales   String[]
  
  // Heridas del alma
  heridaDominante      String
  heridasSecundarias   String[]
  gradosActivacion     Json
  
  // Cuentas pendientes
  cuentasPendientes    Json
  
  // Ciclos y fechas importantes
  diasFuerza           Int[]
  edadTransformacion   Int
  anosTurbulencias     Int
  
  // Análisis completo generado
  analisisCompleto     String
  
  @@map("analisis_cabalistico")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("usuarios")
}
